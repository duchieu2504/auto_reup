# Database & Redis (Dùng cho Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@db:5432/autoreup
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
FPT_AI_API_KEY=your_fpt_api_key_here

# Anti-Detect Browser
ANTI_DETECT_PROVIDER=none
GPM_API_URL=http://127.0.0.1:19995
